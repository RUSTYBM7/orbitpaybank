{
  "expo": {
    "name": "OrbitPay",
    "slug": "orbitpaybank",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "orbitpaybank",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "Q6SJUT5K5D.com.xl.MyXL.Giant-staging",
      "entitlements": "./ios/orbitpaybank.entitlements",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIAccessibilityTraits": [],
        "UIRequiredDeviceCapabilities": ["arm64"],
        "NSCameraUsageDescription": "OrbitPay uses the camera to scan QR codes for fast payments and to capture KYC documents.",
        "NSPhotoLibraryUsageDescription": "OrbitPay needs photo library access to attach documents during KYC verification.",
        "NSPhotoLibraryAddUsageDescription": "OrbitPay saves payment receipts to your photo library.",
        "NSFaceIDUsageDescription": "OrbitPay uses Face ID to securely unlock your account and authorize transactions.",
        "NSLocationWhenInUseUsageDescription": "OrbitPay uses your location to find nearby branches and ATMs.",
        "NSMicrophoneUsageDescription": "OrbitPay uses the microphone for voice-driven AI assistant features.",
        "NSContactsUsageDescription": "OrbitPay reads your contacts to help you send money to people you know.",
        "NSUserNotificationUsageDescription": "OrbitPay sends notifications for transactions, security alerts, and account updates.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIAccessibilityPostNotification": true
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.rustybm.orbitpaybank",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-web-browser",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e529f60-ca2b-4ee0-bed6-09bed8caba0c"
      }
    },
    "owner": "rustybm"
  }
}
